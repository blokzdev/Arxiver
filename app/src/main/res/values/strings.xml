    <string name="verify_fail_token_title">Token rejected</string>
    <string name="verify_fail_token_body">The token was mistyped, revoked, or belongs to another routine. Re-copy it from the routine\'s API trigger settings, then Edit URL &amp; token below.</string>
    <string name="verify_fail_url_title">Trigger not found (HTTP 404)</string>
    <string name="verify_fail_url_body">Check the trigger URL — it should look like https://api.anthropic.com/v1/claude_code/routines/… (the /fire ending is added automatically).</string>
    <string name="verify_fail_badrequest_title">Request rejected (HTTP 400)</string>
    <string name="verify_fail_badrequest_body">You may have pasted the routine\'s page URL instead of its trigger URL. Re-copy the trigger URL from the API trigger settings.</string>
    <string name="verify_fail_rejected_title">Rejected (HTTP %1$d)</string>
    <string name="verify_fail_rejected_title_nocode">Ping rejected</string>
    <string name="verify_fail_rejected_body">The endpoint refused the ping. Check that the routine still exists and its API trigger is enabled.</string>
    <string name="verify_fail_server_title">Claude-side trouble (HTTP %1$d)</string>
    <string name="verify_fail_server_body">Not your fault — the ping is queued and will retry automatically. You can finish setup and test again later.</string>
    <string name="verify_fail_vault_title">Stored token unavailable</string>
    <string name="verify_fail_vault_body">The token can\'t be read on this device (this happens after restoring a backup). Edit URL &amp; token below and re-enter it.</string>

